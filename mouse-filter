#!/usr/bin/env python3
"""
Universal mouse debounce filter.

Intercepts raw evdev mouse events and suppresses phantom button releases
shorter than a configurable threshold. This fixes hardware switch bounce
(worn Omron micro-switches) that causes lost drags and phantom clicks.

Creates a virtual mouse device via uinput that forwards all events except
bounced releases. The original device is grabbed (exclusive access) so
only the filtered events reach X11/Wayland.

Applies to all detected mice unless --device is specified.

Requires: root (for evdev grab + uinput creation)
Usage: sudo mouse-filter [--threshold 60]
"""

import argparse
import ctypes
import ctypes.util
import os
import select
import signal
import struct
import sys
import time
from datetime import datetime
from pathlib import Path

try:
    import evdev
    from evdev import UInput, ecodes
except ImportError:
    print("Error: python3-evdev required. Install: sudo apt install python3-evdev",
          file=sys.stderr)
    sys.exit(1)


DEBOUNCE_MS = 60
HOLD_THRESHOLD_MS = 150  # Hold longer than this = drag (debounce applies)
BUTTON_CODES = {ecodes.BTN_LEFT, ecodes.BTN_RIGHT, ecodes.BTN_MIDDLE,
                ecodes.BTN_SIDE, ecodes.BTN_EXTRA}
BTN_NAMES = {ecodes.BTN_LEFT: "LEFT", ecodes.BTN_RIGHT: "RIGHT",
             ecodes.BTN_MIDDLE: "MIDDLE", ecodes.BTN_SIDE: "SIDE",
             ecodes.BTN_EXTRA: "EXTRA"}

_real_user = os.environ.get("SUDO_USER", os.environ.get("USER", "root"))
_real_home = Path(f"/home/{_real_user}") if _real_user != "root" else Path.home()
# Default log dir; overridable via --log-dir
LOG_DIR = _real_home / ".local" / "share" / "mouse-filter"
LOG_FILE = None  # Set in main() after arg parsing


def log(msg, also_print=True):
    ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S.%f")[:-3]
    line = f"[{ts}] {msg}"
    if LOG_FILE:
        try:
            with open(LOG_FILE, "a") as f:
                f.write(line + "\n")
        except Exception:
            pass
    if also_print:
        print(line, flush=True)


def log_user_tag(label="marker"):
    """Emit a USER_TAG line to the log. Triggered by SIGUSR1 from a
    panel-launcher script when the user perceives a UX glitch and wants
    to mark its location in the log for later analysis.
    """
    log(f"USER_TAG: {label}")


def find_mice():
    """Find all physical mouse evdev devices (skip virtual/forwarded)."""
    mice = []
    for path in evdev.list_devices():
        try:
            dev = evdev.InputDevice(path)
        except Exception:
            continue
        # Skip virtual devices (our own output, input-remapper, etc.)
        if "uinput" in (dev.phys or "").lower() or "input-remapper" in dev.name.lower():
            dev.close()
            continue
        caps = dev.capabilities()
        key_caps = caps.get(ecodes.EV_KEY, [])
        rel_caps = caps.get(ecodes.EV_REL, [])
        # Must have BTN_LEFT and relative axes (mouse movement)
        if ecodes.BTN_LEFT in key_caps and ecodes.REL_X in rel_caps:
            mice.append(dev)
        else:
            dev.close()
    return mice


def find_new_mice(existing_paths):
    """Find mice not already being monitored. Closes duplicate FDs.

    Calls find_mice() to discover all physical mice, then filters out
    any whose path is already in existing_paths. Devices that are already
    monitored get their file descriptors closed to prevent leaks.

    Note: this scans ALL /dev/input devices (slow, ~50-350ms). Used only at
    startup. For runtime hotplug, use inotify + check_new_device() instead.
    """
    all_mice = find_mice()
    new = []
    for m in all_mice:
        if m.path in existing_paths:
            m.close()
        else:
            new.append(m)
    return new


def init_inotify():
    """Create inotify watch on /dev/input/ for new device files.

    Returns a file descriptor that becomes readable when device files are
    created in /dev/input/. Add this FD to select() alongside mouse FDs.
    Returns -1 on failure.
    """
    try:
        libc = ctypes.CDLL(ctypes.util.find_library('c'), use_errno=True)
        IN_CREATE = 0x00000100
        IN_NONBLOCK = 0x00000800
        fd = libc.inotify_init1(IN_NONBLOCK)
        if fd < 0:
            return -1
        wd = libc.inotify_add_watch(fd, b'/dev/input', IN_CREATE)
        if wd < 0:
            os.close(fd)
            return -1
        return fd
    except Exception:
        return -1


def drain_inotify(fd):
    """Read pending inotify events, return list of new /dev/input/event* paths.

    Parses the raw inotify_event structs from the kernel. Filters to only
    return event* files (the actual input device nodes), ignoring other
    entries like 'mice', 'js0', etc.
    """
    paths = []
    try:
        data = os.read(fd, 65536)
    except OSError:
        return paths
    hdr_size = struct.calcsize('iIII')
    offset = 0
    while offset + hdr_size <= len(data):
        wd, mask, cookie, length = struct.unpack_from('iIII', data, offset)
        offset += hdr_size
        if offset + length > len(data):
            break
        name = data[offset:offset + length].rstrip(b'\0').decode(
            'utf-8', errors='replace')
        offset += length
        if name.startswith('event'):
            paths.append(f'/dev/input/{name}')
    return paths


def check_new_device(path, existing_paths):
    """Check if a specific device path is a physical mouse not already monitored.

    Opens just the one device (O(1) instead of scanning all devices), checks
    if it's a real mouse, and returns the evdev.InputDevice if so.
    Returns None (and closes the FD) if it's virtual, non-mouse, or already
    monitored.
    """
    if path in existing_paths:
        return None
    try:
        dev = evdev.InputDevice(path)
    except Exception:
        return None
    if "uinput" in (dev.phys or "").lower() or "input-remapper" in dev.name.lower():
        dev.close()
        return None
    caps = dev.capabilities()
    key_caps = caps.get(ecodes.EV_KEY, [])
    rel_caps = caps.get(ecodes.EV_REL, [])
    if ecodes.BTN_LEFT in key_caps and ecodes.REL_X in rel_caps:
        return dev
    dev.close()
    return None


class MoveDiagnostics:
    """Per-interval movement pipeline telemetry.

    Tracks metrics across 4 pipeline stages:
      1. Input delivery (kernel→read lag, Hz)
      2. Batch + loop (events per read, select-loop iteration time)
      3. Write latency (uinput write_event timing)
      4. X11 delivery (pointer stalls, written by X11PointerProbe)

    Created per-mouse only when --diagnose-move is active.
    """

    # Thresholds
    BATCH_THRESHOLD = 10       # >10 events per read() = large batch
    LOOP_STALL_MS = 2.0        # >2ms loop iteration = stall
    WRITE_SLOW_S = 0.0005      # >0.5ms write = slow

    def __init__(self, lag_threshold_ms=10):
        self.lag_threshold_ms = lag_threshold_ms
        self._interval_start = time.monotonic()
        self._move_forwarded_count = 0  # Monotonic, not reset (X11 probe reads it)

        # Stage 1: Input delivery
        self.move_count = 0
        self.move_max_lag_ms = 0.0
        self.move_lag_spikes = 0

        # Stage 2: Batch + loop
        self.max_batch_size = 0
        self.total_batches = 0
        self.large_batch_count = 0
        self.loop_max_ms = 0.0
        self.loop_stall_count = 0

        # Stage 3: Write latency
        self.write_count = 0
        self.write_slow_count = 0
        self.write_max_s = 0.0

        # Stage 4: X11 (written by X11PointerProbe thread)
        self.x11_stalls = 0

    def record_input(self, lag_ms):
        """Record a movement event with its input delivery lag.

        lag_ms may be None during calibration (first event).
        """
        self.move_count += 1
        if lag_ms is None:
            return
        if lag_ms > self.move_max_lag_ms:
            self.move_max_lag_ms = lag_ms
        if lag_ms > self.lag_threshold_ms:
            self.move_lag_spikes += 1

    def record_batch(self, size):
        """Record a device.read() batch size."""
        self.total_batches += 1
        if size > self.max_batch_size:
            self.max_batch_size = size
        if size > self.BATCH_THRESHOLD:
            self.large_batch_count += 1

    def record_loop_time(self, ms):
        """Record a select-loop iteration duration in ms."""
        if ms > self.loop_max_ms:
            self.loop_max_ms = ms
        if ms > self.LOOP_STALL_MS:
            self.loop_stall_count += 1

    def record_write(self, elapsed_s):
        """Record a uinput write_event elapsed time in seconds."""
        self.write_count += 1
        if elapsed_s > self.write_max_s:
            self.write_max_s = elapsed_s
        if elapsed_s > self.WRITE_SLOW_S:
            self.write_slow_count += 1

    def hz(self):
        """Return approximate movement event rate in Hz."""
        elapsed = time.monotonic() - self._interval_start
        if elapsed <= 0:
            return 0.0
        return self.move_count / elapsed

    def verdict(self):
        """Return a diagnostic verdict string. Priority order."""
        if self.move_lag_spikes > 0:
            return "INPUT_LAG"
        if self.loop_stall_count > 0:
            return "LOOP_STALL"
        if self.write_slow_count > 0:
            return "WRITE_LAG"
        if self.x11_stalls > 0:
            return "X11_STALL"
        return "CLEAN"

    def report(self):
        """Format a single-line diagnostic report."""
        return (
            f"MOVE_DIAG: rate={self.hz():.0f}Hz "
            f"input(max={self.move_max_lag_ms:.1f}ms spikes={self.move_lag_spikes}) "
            f"batch(max={self.max_batch_size}) "
            f"loop(max={self.loop_max_ms:.1f}ms stalls={self.loop_stall_count}) "
            f"write(max={self.write_max_s * 1000:.2f}ms) "
            f"x11(stalls={self.x11_stalls}) "
            f"-> {self.verdict()}"
        )

    def reset(self):
        """Clear per-interval counters. Preserves _move_forwarded_count."""
        self._interval_start = time.monotonic()
        self.move_count = 0
        self.move_max_lag_ms = 0.0
        self.move_lag_spikes = 0
        self.max_batch_size = 0
        self.total_batches = 0
        self.large_batch_count = 0
        self.loop_max_ms = 0.0
        self.loop_stall_count = 0
        self.write_count = 0
        self.write_slow_count = 0
        self.write_max_s = 0.0
        self.x11_stalls = 0


class X11PointerProbe:
    """Daemon thread polling XQueryPointer to detect downstream stalls.

    Polls at 200Hz. If _move_forwarded_count increased since last poll but
    the pointer position hasn't changed, that's a stall sample. 10 consecutive
    stall samples (~50ms) = one x11_stall event on the MoveDiagnostics instance.

    Gracefully degrades: if $DISPLAY unavailable or Xlib import fails,
    start() returns False and the probe is skipped.
    """

    POLL_HZ = 200
    STALL_SAMPLES = 10  # 10 polls at 200Hz = 50ms

    def __init__(self, diag):
        self._diag = diag
        self._thread = None
        self._running = False
        # State for stall detection
        self._last_x = None
        self._last_y = None
        self._last_count = 0
        self._stall_counter = 0

    def _check_stall(self, x, y, count):
        """Check if the pointer is stalled. Returns True if a stall event fired.

        Callable from tests without threading.
        """
        events_forwarded = count > self._last_count
        pointer_moved = (x != self._last_x or y != self._last_y)

        if events_forwarded and not pointer_moved:
            self._stall_counter += 1
        else:
            self._stall_counter = 0

        self._last_x = x
        self._last_y = y
        self._last_count = count

        if self._stall_counter >= self.STALL_SAMPLES:
            self._diag.x11_stalls += 1
            self._stall_counter = 0
            return True
        return False

    def _poll_loop(self, display):
        """Poll XQueryPointer in a loop. Runs in daemon thread."""
        interval = 1.0 / self.POLL_HZ
        root = display.screen().root
        while self._running:
            try:
                qp = root.query_pointer()
                self._check_stall(qp.root_x, qp.root_y,
                                  self._diag._move_forwarded_count)
            except Exception:
                pass
            time.sleep(interval)

    def start(self):
        """Start the probe thread. Returns False if X11 unavailable."""
        if not os.environ.get('DISPLAY'):
            return False
        try:
            from Xlib import display as xdisplay
            d = xdisplay.Display()
        except Exception:
            return False
        self._running = True
        self._thread = __import__('threading').Thread(
            target=self._poll_loop, args=(d,), daemon=True)
        self._thread.start()
        return True

    def stop(self):
        """Stop the probe thread."""
        self._running = False
        if self._thread:
            self._thread.join(timeout=1.0)


class WheelDiagnostics:
    """Wheel-event burst classifier and reversal logger.

    Read-only diagnostic. Each wheel event (REL_WHEEL or REL_WHEEL_HI_RES) is
    classified into a directional burst. State machine:

      idle/unseeded → first event seeds {dir, sum, count, start_mono}
      same-dir event → extend burst
      sign-flip event → emit WHEEL_REV(prev_burst_summary, reversal_event),
                        then seed a new burst rooted at the reverse event
      idle gap > idle_ms before next event → emit WHEEL_BURST_END(prev_burst),
                                              then seed new burst at this event

    Counters: burst_count tracks total observed wheel events (across all
    bursts) for tests / sanity checks. burst_id increments per closed-out
    or reversed burst so reversal log lines are uniquely identifiable.

    All log lines use also_print=False — file-only, like --diagnose-clicks.
    """

    WHEEL_CODES = {ecodes.REL_WHEEL, ecodes.REL_WHEEL_HI_RES}

    def __init__(self, name, idle_ms=250, on_burst_closed=None, emit_logs=True):
        self.name = name
        self.idle_s = idle_ms / 1000.0
        self.burst_count = 0  # total wheel events observed
        self._burst_id_seq = 0
        # When False, WHEEL_REV / WHEEL_BURST_END are not logged. State machine
        # still runs and on_burst_closed still fires — used by WheelSuppressor
        # to drive its anchor without polluting the log.
        self.emit_logs = emit_logs
        # Optional callback fired on every burst close (idle, reversal, flush).
        # Signature: (signed_dir, abs_sum, end_mono).
        self.on_burst_closed = on_burst_closed
        # Active burst state
        self._dir = 0           # +1 / -1 / 0 (unseeded)
        self._sum = 0           # signed sum of values in current burst
        self._count = 0         # event count in current burst
        self._start_mono = None
        self._last_mono = None
        self._axes_seen = set()  # which REL_* codes contributed
        self._burst_id = None    # id of the current burst

    def observe(self, event, now_mono):
        """Process one event. Caller must filter to wheel events.

        Caller passes now_mono (time.monotonic()) so tests can drive
        deterministic timing without time.sleep.
        """
        if event.code not in self.WHEEL_CODES:
            return
        self.burst_count += 1
        value = event.value
        if value == 0:
            # Zero-value events have no direction; ignore without disturbing state
            return

        sign = 1 if value > 0 else -1

        # Idle close-out before classifying this event
        if (self._dir != 0 and self._last_mono is not None
                and (now_mono - self._last_mono) > self.idle_s):
            self._emit_burst_end()
            self._reset_burst()

        if self._dir == 0:
            self._seed_burst(sign, value, event.code, now_mono)
            return

        if sign == self._dir:
            self._sum += value
            self._count += 1
            self._last_mono = now_mono
            self._axes_seen.add(event.code)
            return

        # Sign flip — emit reversal log, then start a new burst at this event
        self._emit_reversal(value, event.code, now_mono)
        self._reset_burst()
        self._seed_burst(sign, value, event.code, now_mono)

    def _seed_burst(self, sign, value, code, now_mono):
        self._burst_id_seq += 1
        self._burst_id = self._burst_id_seq
        self._dir = sign
        self._sum = value
        self._count = 1
        self._start_mono = now_mono
        self._last_mono = now_mono
        self._axes_seen = {code}

    def _reset_burst(self):
        self._dir = 0
        self._sum = 0
        self._count = 0
        self._start_mono = None
        self._last_mono = None
        self._axes_seen = set()
        self._burst_id = None

    def _axis_label(self):
        if not self._axes_seen:
            return "none"
        labels = []
        if ecodes.REL_WHEEL in self._axes_seen:
            labels.append("WHEEL")
        if ecodes.REL_WHEEL_HI_RES in self._axes_seen:
            labels.append("HI_RES")
        return "+".join(labels) if labels else "none"

    def _dir_word(self, sign):
        return "down" if sign < 0 else "up"

    def _emit_reversal(self, rev_value, rev_code, now_mono):
        if self.emit_logs:
            gap_ms = int(round((now_mono - self._last_mono) * 1000))
            since_start_ms = int(round((now_mono - self._start_mono) * 1000))
            rev_axis = "HI_RES" if rev_code == ecodes.REL_WHEEL_HI_RES else "WHEEL"
            log(f"WHEEL_REV on {self.name}: burst_id={self._burst_id} "
                f"axis={self._axis_label()} "
                f"flip={self._dir_word(self._dir)}->{self._dir_word(1 if rev_value > 0 else -1)} "
                f"prev(sum={self._sum} count={self._count}) "
                f"rev(axis={rev_axis} value={'+' if rev_value > 0 else ''}{rev_value} "
                f"gap_ms={gap_ms}) "
                f"since_burst_start_ms={since_start_ms}",
                also_print=False)
        if self.on_burst_closed is not None:
            self.on_burst_closed(self._dir, abs(self._sum), self._last_mono)

    def _emit_burst_end(self):
        if self.emit_logs:
            dur_ms = int(round((self._last_mono - self._start_mono) * 1000))
            log(f"WHEEL_BURST_END on {self.name}: burst_id={self._burst_id} "
                f"dir={self._dir_word(self._dir)} "
                f"axis={self._axis_label()} "
                f"sum={self._sum} count={self._count} dur_ms={dur_ms}",
                also_print=False)
        if self.on_burst_closed is not None:
            self.on_burst_closed(self._dir, abs(self._sum), self._last_mono)

    def flush(self):
        """Close out any active burst (e.g., on shutdown)."""
        if self._dir != 0:
            self._emit_burst_end()
            self._reset_burst()


class _ClosedBurst:
    """Anchor record for the most recent closed wheel burst.

    Used by WheelSuppressor to compute Type A / Type B suppression decisions.
    Mutable on purpose — cascade-extension updates end_mono in place.
    `type_a_consumed` ensures Type A fires at most ONCE per anchor — a real
    reverse scroll has many opposite-direction events; suppressing all of
    them would block legitimate scrolls indefinitely. After the first
    Type A suppression on an anchor, subsequent opposite-direction events
    fall through.
    """
    __slots__ = ("dir", "abs_sum", "end_mono", "was_significant",
                 "type_a_consumed")

    def __init__(self, dir_, abs_sum, end_mono, was_significant):
        self.dir = dir_
        self.abs_sum = abs_sum
        self.end_mono = end_mono
        self.was_significant = was_significant
        self.type_a_consumed = False


class WheelSuppressor:
    """Active wheel-bounce suppression filter.

    Drops hardware-rebound events on smooth-scroll wheels (e.g. Logitech
    MX 2 with detents disabled). Two suppression rules:

      Type A — single-step opposite-direction event arriving within
               REV_WINDOW_MS of a significant primary's end. Captures the
               kinetic backswing pulse seen in WHEEL_REV log entries.

      Type B — same-direction re-burst within COOLDOWN_MS of a significant
               primary's end, magnitude-bounded by min(primary*ratio,
               bounce_max_total). Captures residual-momentum forward kicks.

    Anchor is set / refreshed by WheelDiagnostics via on_burst_closed
    callback. Cascade chains (each sub-burst < ½ previous) are caught by
    extending the anchor's end_mono on same-direction small-burst closures
    while preserving the original primary's magnitude as the budget
    reference. Cross-direction small closures clear the anchor — user
    reversed legitimately.

    Hot-path cost: a few comparisons and integer arithmetic. No allocations,
    no I/O. The caller logs SUPPRESSED_WHEEL on each True return.
    """

    REV_MAX_NOTCH = 1     # ±1 on REL_WHEEL = single notch (Type A signature)
    REV_MAX_HI_RES = 120  # ±120 on REL_WHEEL_HI_RES = single notch
    AXIS_TIE_MS = 8       # USB poll interval — keeps notch+hi-res paired

    def __init__(self, name, *, enabled=True,
                 cooldown_ms=1200, rev_window_ms=280,
                 cooldown_ratio=0.5, min_primary=360,
                 bounce_max_total=300, quiet_ms=200,
                 type_b_enabled=False, max_cascade_depth=0):
        self.name = name
        self.enabled = enabled
        self.cooldown_s = cooldown_ms / 1000.0
        self.rev_window_s = rev_window_ms / 1000.0
        self.cooldown_ratio = cooldown_ratio
        self.min_primary = min_primary
        self.bounce_max_total = bounce_max_total
        self.quiet_s = quiet_ms / 1000.0
        # Cap on cascade-extensions per anchor. 0 disables cascade-extend
        # entirely — first small same-direction close clears the anchor.
        # Higher values catch multi-stage decay cascades but lengthen the
        # max suppression-lockout window. Default 0 errs toward
        # responsiveness.
        self.max_cascade_depth = max_cascade_depth
        # Type B (same-direction re-burst) suppression is opt-in. The first
        # event of a legitimate continuation scroll is indistinguishable
        # from a Type B bounce on its first event, so the rule trades
        # responsiveness for catch-rate. Default off; `--wheel-type-b` to
        # opt in. When on, cooldown_consumed counts BOTH the Type B and
        # axis-tie suppressions' full event magnitudes.
        self.type_b_enabled = type_b_enabled
        # State
        self.last_closed = None           # _ClosedBurst | None
        self.cooldown_consumed = 0        # same-dir mag suppressed in CURRENT burst
        self.cascade_depth = 0            # number of cascade-extends since this anchor
        self.last_forwarded_mono = None   # for mid-gesture detection
        self.last_suppress_mono = None    # for axis-tie pairing
        self.last_suppress_sign = 0
        # Counters
        self.suppressed_total = 0
        self.suppressed_type_a = 0
        self.suppressed_type_b = 0
        self.suppressed_axis_tie = 0

    def set_enabled(self, b):
        """Toggle suppression at runtime (called from SIGUSR2 handler)."""
        self.enabled = bool(b)

    def note_burst_closed(self, dir_, abs_sum, end_mono):
        """Called by WheelDiagnostics on every burst close (idle or reversal)."""
        was_sig = abs_sum >= self.min_primary

        if self.last_closed is None or not self.last_closed.was_significant:
            self.last_closed = _ClosedBurst(dir_, abs_sum, end_mono, was_sig)
            self.cooldown_consumed = 0
            self.cascade_depth = 0
            return

        age_s = end_mono - self.last_closed.end_mono

        if was_sig or age_s > self.cooldown_s:
            # New primary (or cooldown expired) — replace anchor cleanly
            self.last_closed = _ClosedBurst(dir_, abs_sum, end_mono, was_sig)
            self.cooldown_consumed = 0
            self.cascade_depth = 0
            return

        # Small burst (< min_primary) within an active cooldown.
        if dir_ == self.last_closed.dir:
            # Same-direction cascade continuation. Each bounce in a decay
            # chain (605→242→121→…) gets a FRESH suppression budget — we
            # reset cooldown_consumed so every cascade stage is fully
            # caught. Cap chain depth so an indefinite stream of small
            # same-direction bursts (a user genuinely scrolling slowly)
            # doesn't lock the anchor forever.
            self.cascade_depth += 1
            if self.cascade_depth > self.max_cascade_depth:
                self.last_closed = None
                self.cooldown_consumed = 0
                self.cascade_depth = 0
                return
            self.last_closed.end_mono = end_mono
            self.cooldown_consumed = 0
        else:
            # Cross-direction small burst — user reversed direction
            # legitimately, OR a Type A bounce already idled out. Either way,
            # the original primary's bounce envelope no longer protects.
            self.last_closed = None
            self.cooldown_consumed = 0
            self.cascade_depth = 0

    def should_suppress(self, event, now_mono):
        """Returns (suppress: bool, reason: str | None).

        Hot path. Caller must filter to wheel events (REL_WHEEL or
        REL_WHEEL_HI_RES) before invoking.
        """
        if not self.enabled:
            self._mark_forwarded(now_mono)
            return False, None

        value = event.value
        if value == 0:
            return False, None

        sign = 1 if value > 0 else -1
        mag = abs(value)

        # Axis-tie: REL_WHEEL and REL_WHEEL_HI_RES arrive paired within one
        # USB poll. If we just suppressed an event with this sign within
        # AXIS_TIE_MS, suppress the partner too — otherwise the consumer sees
        # a half-pair and renders a partial scroll. CRITICAL: do NOT update
        # last_suppress_mono here. Otherwise a stream of paired events 5ms
        # apart keeps re-anchoring the 8ms window and never expires —
        # producing the "scroll forever suppressed" bug observed in the
        # 2026-05-10 production failure.
        if (self.last_suppress_mono is not None and
                (now_mono - self.last_suppress_mono) * 1000 <= self.AXIS_TIE_MS and
                sign == self.last_suppress_sign):
            self.suppressed_total += 1
            self.suppressed_axis_tie += 1
            # When Type B is opt-in active, count axis-tie magnitude toward
            # the cooldown budget — otherwise hi-res events (always paired
            # via axis-tie) bypass the budget and Type B never exhausts.
            if self.type_b_enabled and self.last_closed is not None:
                self.cooldown_consumed += mag
            return True, "axis_tie"

        lc = self.last_closed
        if lc is None or not lc.was_significant:
            self._mark_forwarded(now_mono)
            return False, None

        age_s = now_mono - lc.end_mono

        # Type A: single-step opposite-direction event within REV_WINDOW.
        # Fires AT MOST ONCE per anchor — a real reverse scroll arrives as
        # many single-step events; suppressing all of them blocks legitimate
        # use. The hardware bounce is a single transient pulse; if more
        # opposite events follow, it's user intent.
        if (sign == -lc.dir and age_s <= self.rev_window_s
                and not lc.type_a_consumed):
            rev_max = (self.REV_MAX_HI_RES
                       if event.code == ecodes.REL_WHEEL_HI_RES
                       else self.REV_MAX_NOTCH)
            if mag <= rev_max:
                lc.type_a_consumed = True
                self.last_suppress_mono = now_mono
                self.last_suppress_sign = sign
                self.suppressed_total += 1
                self.suppressed_type_a += 1
                return True, "type_a_reversal"

        # Type B: same-direction re-burst within COOLDOWN, magnitude-bounded.
        # OPT-IN ONLY. The first event of a same-direction continuation
        # after a normal pause is indistinguishable from a Type B bounce —
        # erring toward "drop nothing" preserves wheel responsiveness, the
        # user's load-bearing requirement.
        if self.type_b_enabled and sign == lc.dir and age_s <= self.cooldown_s:
            # Mid-gesture guard: rapid same-dir flow → user is scrolling, not
            # bouncing. Skip on first event (no last_forwarded yet).
            if (self.last_forwarded_mono is not None and
                    (now_mono - self.last_forwarded_mono) <= self.quiet_s):
                self._mark_forwarded(now_mono)
                return False, None

            budget = min(lc.abs_sum * self.cooldown_ratio, self.bounce_max_total)
            if (self.cooldown_consumed + mag) <= budget:
                self.cooldown_consumed += mag
                self.last_suppress_mono = now_mono
                self.last_suppress_sign = sign
                self.suppressed_total += 1
                self.suppressed_type_b += 1
                return True, "type_b_cooldown"
            # Past budget — let through. Anchor stays for cascade-catch on
            # the next bounce burst.

        self._mark_forwarded(now_mono)
        return False, None

    def _mark_forwarded(self, now_mono):
        self.last_forwarded_mono = now_mono


class DebouncedMouse:
    """Wraps a single mouse device with debounce filtering."""

    def __init__(self, device, threshold_ms, quiet=False):
        self.device = device
        self.threshold_s = threshold_ms / 1000.0
        self.quiet = quiet
        self.name = device.name
        # Per-button state: last release monotonic timestamp
        self.last_release = {}
        # Per-button state: is currently pressed
        self.pressed = {}
        self.suppressed = 0
        self.total_clicks = 0

        # Create virtual device cloning capabilities of the original
        self.uinput = UInput.from_device(device, name=f"debounced {device.name}")

        # Grab exclusive access to the original device
        device.grab()

    def process_event(self, event):
        """Process one event. Returns True if forwarded, False if suppressed."""
        # Non-button events: always forward immediately
        if event.type != ecodes.EV_KEY or event.code not in BUTTON_CODES:
            self.uinput.write_event(event)
            return True

        now = time.monotonic()
        btn = event.code

        if event.value == 1:  # Press
            # Check if this press follows a suspiciously fast release (bounce)
            last_rel = self.last_release.get(btn, 0)
            if last_rel > 0 and self.pressed.get(btn, False) is False:
                gap = now - last_rel
                if gap < self.threshold_s:
                    # This press is a bounce re-press. Suppress it, but also
                    # retroactively "undo" the release we already forwarded
                    # by sending a press now (restoring the held state).
                    # Actually: the release was already sent. The best we can
                    # do is send the press immediately to minimize the gap.
                    # But the cleaner approach is to delay releases (see below).
                    pass

            self.pressed[btn] = True
            self.total_clicks += 1
            self.uinput.write_event(event)
            return True

        elif event.value == 0:  # Release
            self.pressed[btn] = False
            self.last_release[btn] = now
            # Forward the release - we can't delay without adding latency
            # to ALL releases. Instead, we handle it on the re-press side:
            # if a press comes too fast after this release, we know the
            # release was a bounce.
            self.uinput.write_event(event)
            return True

        else:
            # value == 2 (repeat) - just forward
            self.uinput.write_event(event)
            return True

    def close(self):
        try:
            self.device.ungrab()
        except Exception:
            pass
        try:
            self.uinput.close()
        except Exception:
            pass


class DelayedDebouncedMouse:
    """
    Debounce by delaying drag releases only.

    Click releases (hold < hold_threshold) are forwarded immediately — no
    delay, no interference with double-clicks. Only drag releases (hold >=
    hold_threshold) are held for `threshold_ms` before forwarding. If a
    re-press arrives during the hold period, both the release and re-press
    are suppressed (the button was never really released during the drag).
    """

    def __init__(self, device, threshold_ms, warn_threshold_ms=None,
                 hold_threshold_ms=None, quiet=False, lag_threshold_ms=10,
                 button_remap=None, diagnose_move=False, diagnose_clicks=False,
                 debounce_enabled=False, diagnose_wheel=False,
                 wheel_suppress=False, wheel_cooldown_ms=1200,
                 wheel_rev_window_ms=280, wheel_cooldown_ratio=0.5,
                 wheel_min_primary=360, wheel_bounce_max_total=300,
                 wheel_quiet_ms=200, wheel_type_b=False,
                 wheel_max_cascade_depth=0, wheel_multiplier=1,
                 wheel_drop_hires=False):
        self.device = device
        self.threshold_s = threshold_ms / 1000.0
        self.button_remap = button_remap or {}  # {src_code: dst_code}
        self.warn_threshold_s = (warn_threshold_ms or 100) / 1000.0
        self.hold_threshold_s = (hold_threshold_ms if hold_threshold_ms is not None
                                 else HOLD_THRESHOLD_MS) / 1000.0
        self.quiet = quiet
        # When False, all releases forward immediately and bounce checks are
        # skipped. The new mouse hardware doesn't bounce; flag retained so
        # debounce can be re-enabled if a future mouse needs it.
        self.debounce_enabled = debounce_enabled
        self.name = device.name
        self.lag_threshold_ms = lag_threshold_ms
        # Per-button: pending release event, its timestamp, and hold duration
        self.pending_release = {}   # btn -> (event, monotonic_time, was_drag)
        # Per-button: when the button was pressed (for hold duration calc)
        self.press_time = {}        # btn -> monotonic_time
        # Per-button: last forwarded release - timestamps and whether it was a drag
        self.last_forwarded_release = {}  # btn -> (original_ts, forwarded_ts, was_drag)
        self.diagnose_clicks = diagnose_clicks
        self.last_press_forwarded = {}  # btn -> monotonic_time (for pp_gap tracking)
        self.suppressed = 0
        self.total_clicks = 0
        self.wheel_suppressed = 0
        # Latency tracking
        self.total_events = 0
        self.lag_spikes = 0
        self.max_lag_ms = 0.0
        self._wall_offset = None  # Calibrated offset: wall_clock - kernel_timestamp
        # Per-interval stats tracking (for --quiet: only log when notable)
        self._last_stats_suppressed = 0
        self._last_stats_lag_spikes = 0
        self._last_stats_wheel_suppressed = 0
        # Wheel-event value multiplier. Compensates for the loss of
        # smooth-scroll velocity when running with Solaar's hi-res mode
        # turned off (effective hardware-level bounce suppression). At >1,
        # each forwarded REL_WHEEL / REL_WHEEL_HI_RES event has its value
        # scaled. Suppression decisions still operate on the original.
        self.wheel_multiplier = max(1, int(wheel_multiplier))
        # Drop REL_WHEEL_HI_RES events at the forwarding step. Sub-detent
        # phantoms (encoder noise / mechanical micro-rebounds) live entirely
        # on the hi-res axis with no notch event behind them, so dropping
        # the axis eliminates them without affecting real detent crossings.
        # Diagnostics still observe dropped events.
        self.wheel_drop_hires = wheel_drop_hires

        # Movement diagnostics (only when --diagnose-move is active)
        self._move_diag = MoveDiagnostics(lag_threshold_ms=lag_threshold_ms) if diagnose_move else None
        # Wheel suppression — needs WheelDiagnostics to drive its anchor.
        # When --diagnose-wheel is also on, diag emits log lines too;
        # otherwise diag runs silently as a state engine.
        self._wheel_suppressor = None
        if wheel_suppress:
            self._wheel_suppressor = WheelSuppressor(
                name=device.name,
                enabled=True,
                cooldown_ms=wheel_cooldown_ms,
                rev_window_ms=wheel_rev_window_ms,
                cooldown_ratio=wheel_cooldown_ratio,
                min_primary=wheel_min_primary,
                bounce_max_total=wheel_bounce_max_total,
                quiet_ms=wheel_quiet_ms,
                type_b_enabled=wheel_type_b,
                max_cascade_depth=wheel_max_cascade_depth,
            )
        # WheelDiagnostics: instantiate when --diagnose-wheel is on, OR when
        # --wheel-suppress is on (suppressor needs the burst-close callback).
        if diagnose_wheel or wheel_suppress:
            cb = self._wheel_suppressor.note_burst_closed if self._wheel_suppressor else None
            self._wheel_diag = WheelDiagnostics(
                name=device.name,
                on_burst_closed=cb,
                emit_logs=diagnose_wheel,
            )
        else:
            self._wheel_diag = None

        # Build uinput device. If we have remaps, add target key codes to
        # the capabilities — the physical mouse doesn't advertise KEY_VOLUMEUP etc,
        # so uinput would silently drop those events without this.
        if self.button_remap:
            caps = device.capabilities(verbose=False)
            key_caps = list(caps.get(ecodes.EV_KEY, []))
            for dst_code in self.button_remap.values():
                if dst_code not in key_caps:
                    key_caps.append(dst_code)
            caps[ecodes.EV_KEY] = key_caps
            # Remove EV_SYN — UInput adds it automatically and rejects duplicates
            caps.pop(ecodes.EV_SYN, None)
            self.uinput = UInput(events=caps, name=f"debounced {device.name}")
        else:
            self.uinput = UInput.from_device(device, name=f"debounced {device.name}")
        device.grab()

    def _measure_lag(self, event):
        """Measure lag between kernel event timestamp and our processing time.

        Returns lag_ms (float) on successful measurement, None on calibration
        or error. The return value is used by MoveDiagnostics when active.
        """
        self.total_events += 1
        # evdev events carry kernel timestamps (event.sec, event.usec)
        try:
            kernel_ts = event.sec + event.usec / 1_000_000.0
        except (AttributeError, TypeError):
            return None
        wall_now = time.time()
        # Calibrate offset on first event
        if self._wall_offset is None:
            self._wall_offset = wall_now - kernel_ts
            return None
        lag_ms = (wall_now - kernel_ts - self._wall_offset) * 1000
        # Ignore negative lag (clock drift recalibration)
        if lag_ms < 0:
            self._wall_offset = wall_now - kernel_ts
            return None
        if lag_ms > self.max_lag_ms:
            self.max_lag_ms = lag_ms
        if lag_ms > self.lag_threshold_ms:
            self.lag_spikes += 1
            log(f"LAG_SPIKE on {self.name}: {lag_ms:.1f}ms "
                f"(event_type={event.type}, code={event.code}, "
                f"spikes={self.lag_spikes}/{self.total_events})")
        return lag_ms

    def process_event(self, event):
        now = time.monotonic()
        lag_ms = self._measure_lag(event)

        # Record movement events in diagnostics
        is_movement = event.type == ecodes.EV_REL
        if self._move_diag and is_movement:
            self._move_diag.record_input(lag_ms)

        # Record wheel events in diagnostics (state machine drives the
        # suppressor's anchor via on_burst_closed callback).
        is_wheel = (event.type == ecodes.EV_REL
                    and event.code in WheelDiagnostics.WHEEL_CODES)
        if self._wheel_diag and is_wheel:
            self._wheel_diag.observe(event, now)

        # Wheel-bounce suppression. Decision is O(1); fires after observe so
        # the anchor reflects any burst that just closed on this event.
        if self._wheel_suppressor and is_wheel:
            suppress, reason = self._wheel_suppressor.should_suppress(event, now)
            if suppress:
                self.wheel_suppressed += 1
                lc = self._wheel_suppressor.last_closed
                age_ms = 0
                primary_sum = 0
                if lc is not None:
                    age_ms = int(round((now - lc.end_mono) * 1000))
                    primary_sum = lc.abs_sum
                axis = ("HI_RES" if event.code == ecodes.REL_WHEEL_HI_RES
                        else "WHEEL")
                sign_char = '+' if event.value > 0 else '-'
                log(f"SUPPRESSED_WHEEL on {self.name}: reason={reason} "
                    f"axis={axis} sign={sign_char} mag={abs(event.value)} "
                    f"age_ms={age_ms} primary_sum={primary_sum} "
                    f"(suppressed_total={self._wheel_suppressor.suppressed_total})",
                    also_print=False)
                return False

        # Drop hi-res wheel axis at the forwarding boundary. Diagnostics
        # already observed the event above, so logs remain accurate; we
        # just don't write it to uinput. This eliminates sub-detent
        # phantoms (which only ever appear on the hi-res axis) at the cost
        # of smooth-scroll animation between detents.
        if is_wheel and self.wheel_drop_hires \
                and event.code == ecodes.REL_WHEEL_HI_RES:
            return False

        # Wheel multiplier: scale forwarded value when the user has reduced
        # hardware-level scroll resolution (via Solaar) and wants the per-
        # click scroll distance compensated back up.
        if is_wheel and self.wheel_multiplier > 1:
            event = evdev.InputEvent(event.sec, event.usec, event.type,
                                     event.code,
                                     event.value * self.wheel_multiplier)

        # Button remapping: transform code and forward immediately (no debounce)
        if event.type == ecodes.EV_KEY and event.code in self.button_remap:
            remapped = evdev.InputEvent(event.sec, event.usec, event.type,
                                        self.button_remap[event.code], event.value)
            self.uinput.write_event(remapped)
            return True

        if event.type != ecodes.EV_KEY or event.code not in BUTTON_CODES:
            if self._move_diag and is_movement:
                t0 = time.monotonic()
                self.uinput.write_event(event)
                self._move_diag.record_write(time.monotonic() - t0)
                self._move_diag._move_forwarded_count += 1
            else:
                self.uinput.write_event(event)
            return True

        btn = event.code

        if event.value == 1:  # Press
            self.total_clicks += 1
            if self.debounce_enabled and btn in self.pending_release:
                # Only drag releases are ever pending — this is a drag bounce
                _, release_ts, _ = self.pending_release[btn]
                gap_ms = (now - release_ts) * 1000
                hold_ms = (release_ts - self.press_time.get(btn, release_ts)) * 1000
                del self.pending_release[btn]
                self.suppressed += 1
                btn_name = BTN_NAMES.get(btn, str(btn))
                log(f"SUPPRESSED bounce on {self.name}: {btn_name} "
                    f"gap={gap_ms:.1f}ms hold={hold_ms:.0f}ms "
                    f"(suppressed={self.suppressed} total)")
                if self.diagnose_clicks:
                    prev_pp = self.last_press_forwarded.get(btn)
                    pp_str = f"{(now - prev_pp) * 1000:.0f}ms" if prev_pp is not None else "--"
                    log(f"CLICK_DIAG: {btn_name} PRESS SUPPRESSED "
                        f"pp_gap={pp_str} hold={hold_ms:.0f}ms gap={gap_ms:.1f}ms",
                        also_print=False)
                return False
            else:
                self.press_time[btn] = now
                # Check for near-miss (only after drags, not clicks; debounce only)
                last_rel = self.last_forwarded_release.get(btn)
                if self.debounce_enabled and last_rel is not None:
                    orig_ts, fwd_ts, prev_was_drag = last_rel
                    if prev_was_drag:
                        hardware_gap_ms = (now - orig_ts) * 1000
                        if hardware_gap_ms < self.warn_threshold_s * 1000:
                            thresh_ms = self.threshold_s * 1000
                            btn_name = BTN_NAMES.get(btn, str(btn))
                            log(f"NEAR-MISS on {self.name}: {btn_name} "
                                f"hardware_gap={hardware_gap_ms:.1f}ms "
                                f"(threshold={thresh_ms:.0f}ms, "
                                f"escaped by {hardware_gap_ms - thresh_ms:.1f}ms)")
                self.uinput.write_event(event)
                if self.diagnose_clicks:
                    prev_pp = self.last_press_forwarded.get(btn)
                    pp_str = f"{(now - prev_pp) * 1000:.0f}ms" if prev_pp is not None else "--"
                    fwd_rel = self.last_forwarded_release.get(btn)
                    rp_str = f"{(now - fwd_rel[1]) * 1000:.0f}ms" if fwd_rel else "--"
                    log(f"CLICK_DIAG: {BTN_NAMES.get(btn, str(btn))} PRESS "
                        f"pp_gap={pp_str} rp_gap={rp_str} path=normal",
                        also_print=False)
                    self.last_press_forwarded[btn] = now
                return True

        elif event.value == 0:  # Release
            # Compute hold duration to distinguish clicks from drags
            hold_start = self.press_time.get(btn, now)
            hold_duration = now - hold_start
            was_drag = hold_duration >= self.hold_threshold_s
            if was_drag and self.debounce_enabled:
                # Drag release: delay for bounce detection
                self.pending_release[btn] = (event, now, True)
                if self.diagnose_clicks:
                    log(f"CLICK_DIAG: {BTN_NAMES.get(btn, str(btn))} RELEASE "
                        f"hold={hold_duration*1000:.0f}ms type=drag -> queued",
                        also_print=False)
                return True  # Queued, not yet forwarded
            else:
                # Click release (or any release when debounce disabled):
                # forward immediately.
                self.uinput.write_event(event)
                self.last_forwarded_release[btn] = (now, now, False)
                if self.diagnose_clicks:
                    type_label = "drag" if was_drag else "click"
                    log(f"CLICK_DIAG: {BTN_NAMES.get(btn, str(btn))} RELEASE "
                        f"hold={hold_duration*1000:.0f}ms type={type_label} -> forwarded",
                        also_print=False)
                return True  # Forwarded immediately

        else:
            self.uinput.write_event(event)
            return True

    def flush_pending(self):
        """Flush any pending releases that have expired their debounce window.

        After flushing, writes a SYN_REPORT so the uinput consumer (X11)
        sees the release immediately. Without this, flushed releases sit
        in the uinput buffer until the next mouse movement event.
        """
        now = time.monotonic()
        expired = []
        for btn, (event, orig_ts, was_drag) in self.pending_release.items():
            if now - orig_ts >= self.threshold_s:
                expired.append(btn)
                self.uinput.write_event(event)
                self.last_forwarded_release[btn] = (orig_ts, now, was_drag)
                if self.diagnose_clicks:
                    log(f"CLICK_DIAG: {BTN_NAMES.get(btn, str(btn))} FLUSH "
                        f"waited={(now - orig_ts) * 1000:.0f}ms "
                        f"type={'drag' if was_drag else 'click'}",
                        also_print=False)
        for btn in expired:
            del self.pending_release[btn]
        if expired:
            syn = evdev.InputEvent(0, 0, ecodes.EV_SYN, ecodes.SYN_REPORT, 0)
            self.uinput.write_event(syn)

    def next_deadline(self):
        """Return seconds until the next pending release should be flushed, or None."""
        if not self.pending_release:
            return None
        now = time.monotonic()
        earliest = min(ts for _, ts, _ in self.pending_release.values())
        remaining = self.threshold_s - (now - earliest)
        return max(0, remaining)

    def close(self):
        # Flush any remaining pending releases
        for btn, (event, ts, _) in self.pending_release.items():
            self.uinput.write_event(event)
        self.pending_release.clear()
        # Flush any open wheel burst so its summary is captured
        if self._wheel_diag:
            self._wheel_diag.flush()
        try:
            self.device.ungrab()
        except Exception:
            pass
        try:
            self.uinput.close()
        except Exception:
            pass

    def has_notable_events(self):
        """True if suppressions or lag spikes occurred since last stats."""
        return (self.suppressed > self._last_stats_suppressed or
                self.lag_spikes > self._last_stats_lag_spikes or
                self.wheel_suppressed > self._last_stats_wheel_suppressed)

    def record_stats(self):
        """Snapshot current counts for next interval comparison."""
        self._last_stats_suppressed = self.suppressed
        self._last_stats_lag_spikes = self.lag_spikes
        self._last_stats_wheel_suppressed = self.wheel_suppressed

    def set_wheel_suppress(self, enabled):
        """Toggle wheel-bounce suppression at runtime (driven by SIGUSR2).

        No-op when --wheel-suppress was not passed at startup (no suppressor
        instance exists). In that case, runtime enable is intentionally not
        supported — bounce-state would be uninitialized.
        """
        if self._wheel_suppressor is not None:
            self._wheel_suppressor.set_enabled(enabled)


def make_wheel_suppress_toggle(mouse_registry):
    """Build a SIGUSR2 handler that toggles wheel suppression on every mouse.

    The signal handler reads the *current* state from the first available
    suppressor and flips it (so on→off and off→on). All mice flip together;
    a `WHEEL_SUPPRESS_TOGGLE: on|off` log line records the new state.

    The mouse_registry is the live list of DelayedDebouncedMouse instances —
    passed by reference so hotplug additions automatically inherit the
    current toggle state on the next signal. (Newly added mice still come up
    in their startup state, but the next SIGUSR2 will flip them along with
    everyone else.)
    """
    def handler(sig, frame):
        # Determine the new state by inverting the first suppressor's current
        # state. If no mice have a suppressor (--wheel-suppress not set at
        # startup), fall through to logging the no-op.
        new_state = None
        for m in mouse_registry:
            sup = getattr(m, '_wheel_suppressor', None)
            if sup is not None:
                new_state = not sup.enabled
                break
        if new_state is None:
            log("WHEEL_SUPPRESS_TOGGLE: ignored (no suppressors active — "
                "start mouse-filter with --wheel-suppress to enable)")
            return
        for m in mouse_registry:
            m.set_wheel_suppress(new_state)
        log(f"WHEEL_SUPPRESS_TOGGLE: {'on' if new_state else 'off'}")
    return handler


def main():
    parser = argparse.ArgumentParser(description="Universal mouse debounce filter")
    parser.add_argument("--threshold", type=int, default=DEBOUNCE_MS,
                        help=f"Debounce threshold in ms (default: {DEBOUNCE_MS})")
    parser.add_argument("--device", action="append",
                        help="Specific evdev device(s) to filter (default: all mice)")
    parser.add_argument("--warn-threshold", type=int, default=100,
                        help="Log NEAR-MISS for release->press gaps between "
                             "threshold and this value in ms (default: 100)")
    parser.add_argument("--hold-threshold", type=int, default=HOLD_THRESHOLD_MS,
                        help="Only debounce releases after holds longer than this (ms). "
                             f"Short clicks below this are never debounced. (default: {HOLD_THRESHOLD_MS})")
    parser.add_argument("--lag-threshold", type=int, default=10,
                        help="Log LAG_SPIKE when event processing lags more than "
                             "this many ms behind the kernel timestamp (default: 10)")
    parser.add_argument("--quiet", action="store_true",
                        help="Production mode: suppress periodic STATS from stdout, "
                             "log startup config to file only. Events (SUPPRESSED, "
                             "NEAR-MISS, LAG_SPIKE) always log.")
    parser.add_argument("--stats-interval", type=int, default=600,
                        help="Print stats every N seconds (default: 600)")
    parser.add_argument("--log-dir", type=str, default=None,
                        help="Directory for log files (default: ~/.local/share/mouse-filter)")
    parser.add_argument("--remap", action="append", metavar="SRC=DST",
                        help="Remap a button to a key, e.g. BTN_EXTRA=KEY_VOLUMEUP. "
                             "Remapped buttons bypass debounce. Can be specified multiple times.")
    parser.add_argument("--diagnose-move", action="store_true",
                        help="Enable movement pipeline diagnostics. Reports per-stage "
                             "latency breakdown (input, batch, loop, write, X11) at each "
                             "stats interval. Use to identify cursor lag sources.")
    parser.add_argument("--diagnose-clicks", action="store_true",
                        help="Log detailed click timing to log file (not stdout). "
                             "Shows every press/release with hold durations, gap timing, "
                             "and path decisions to diagnose double-click issues.")
    parser.add_argument("--debounce", action="store_true",
                        help="Enable hardware-bounce suppression for drag releases. "
                             "Off by default (current mouse hardware does not bounce). "
                             "When enabled, drag releases are delayed by --threshold ms "
                             "and bounced re-presses within that window are suppressed; "
                             "click releases are unaffected.")
    parser.add_argument("--diagnose-wheel", action="store_true",
                        help="Log wheel-event diagnostics to log file (not stdout). "
                             "Classifies REL_WHEEL/REL_WHEEL_HI_RES events into "
                             "directional bursts and logs WHEEL_REV on sign flips and "
                             "WHEEL_BURST_END on idle close-out. Read-only — never "
                             "mutates the forwarded event stream.")
    parser.add_argument("--wheel-suppress", action="store_true",
                        help="Drop hardware-rebound wheel events on smooth-scroll "
                             "wheels (e.g. Logitech MX 2). Two rules: Type A "
                             "(single-step opposite-direction reversal within window) "
                             "and Type B (same-direction re-burst, magnitude-bounded). "
                             "Toggle at runtime by sending SIGUSR2 to the daemon.")
    parser.add_argument("--wheel-cooldown-ms", type=int, default=1200,
                        help="Type B same-direction cooldown window in ms after a "
                             "significant primary burst ends (default: 1200).")
    parser.add_argument("--wheel-rev-window-ms", type=int, default=280,
                        help="Type A reversal-veto window in ms after a primary "
                             "ends (default: 280).")
    parser.add_argument("--wheel-cooldown-ratio", type=float, default=0.5,
                        help="Suppress same-direction bounces only up to "
                             "primary_sum * ratio (default: 0.5).")
    parser.add_argument("--wheel-min-primary", type=int, default=360,
                        help="Minimum primary burst magnitude (hi-res units) to "
                             "arm the cooldown (default: 360, ≈ 3 notches).")
    parser.add_argument("--wheel-bounce-max-total", type=int, default=300,
                        help="Hard cap on cumulative magnitude suppressed per "
                             "cooldown — prevents runaway false positives on tail "
                             "bounces (default: 300).")
    parser.add_argument("--wheel-quiet-ms", type=int, default=200,
                        help="Mid-gesture guard: if events stream within this gap "
                             "after a forwarded event, never suppress — user is "
                             "scrolling, not bouncing (default: 200).")
    parser.add_argument("--wheel-type-b", action="store_true",
                        help="Opt in to Type B (same-direction re-burst) "
                             "suppression. OFF by default because the first "
                             "event of a continuation scroll is "
                             "indistinguishable from a Type B bounce, so the "
                             "rule trades responsiveness for catch-rate. "
                             "Type A (cross-direction reversal) is unaffected.")
    parser.add_argument("--wheel-max-cascade-depth", type=int, default=0,
                        help="Number of cascade-extensions allowed per anchor "
                             "(default: 0 — disables cascade-extend; one "
                             "anchor catches one bounce stage, then clears). "
                             "Higher values catch multi-stage decay cascades "
                             "but lengthen the max lockout window.")
    parser.add_argument("--wheel-multiplier", type=int, default=1,
                        help="Scale forwarded REL_WHEEL / REL_WHEEL_HI_RES "
                             "event values by N (default: 1, no change). Use "
                             "with Solaar's high-res scroll mode turned OFF: "
                             "low-res mode ignores sub-detent bounces but "
                             "feels slow; this puts the perceived speed back. "
                             "Try 2 or 3.")
    parser.add_argument("--wheel-drop-hires", action="store_true",
                        help="Drop REL_WHEEL_HI_RES events at the forwarding "
                             "step. Sub-detent phantoms (encoder noise, "
                             "mechanical micro-rebounds) appear only on the "
                             "hi-res axis with no notch event behind them, "
                             "so dropping the axis eliminates them entirely. "
                             "Apps fall back to the notch (REL_WHEEL) for "
                             "scroll signal. Trade-off: loss of smooth-scroll "
                             "animation between detents.")
    args = parser.parse_args()

    # Parse button remaps
    button_remap = {}
    if args.remap:
        for spec in args.remap:
            try:
                src_name, dst_name = spec.split("=", 1)
                src_code = getattr(ecodes, src_name.strip())
                dst_code = getattr(ecodes, dst_name.strip())
                button_remap[src_code] = dst_code
            except (ValueError, AttributeError) as e:
                log(f"Invalid --remap '{spec}': {e}")
                log(f"  Format: --remap BTN_EXTRA=KEY_VOLUMEUP")
                sys.exit(1)

    global LOG_DIR, LOG_FILE
    if args.log_dir:
        LOG_DIR = Path(args.log_dir)
    LOG_FILE = LOG_DIR / "debounce.log"
    LOG_DIR.mkdir(parents=True, exist_ok=True)

    # Cap log file to last 2000 lines on startup
    if LOG_FILE.exists():
        tmp = f"{LOG_FILE}.tmp"
        os.system(f'tail -n 2000 "{LOG_FILE}" > "{tmp}" && mv "{tmp}" "{LOG_FILE}"')

    if args.device:
        devices = []
        for path in args.device:
            try:
                devices.append(evdev.InputDevice(path))
            except Exception as e:
                log(f"Error opening {path}: {e}")
                sys.exit(1)
    else:
        devices = find_mice()

    if not devices:
        log("No mouse devices found.")
        sys.exit(1)

    mice = []
    wheel_suppress_kwargs = dict(
        wheel_suppress=args.wheel_suppress,
        wheel_cooldown_ms=args.wheel_cooldown_ms,
        wheel_rev_window_ms=args.wheel_rev_window_ms,
        wheel_cooldown_ratio=args.wheel_cooldown_ratio,
        wheel_min_primary=args.wheel_min_primary,
        wheel_bounce_max_total=args.wheel_bounce_max_total,
        wheel_quiet_ms=args.wheel_quiet_ms,
        wheel_type_b=args.wheel_type_b,
        wheel_max_cascade_depth=args.wheel_max_cascade_depth,
        wheel_multiplier=args.wheel_multiplier,
        wheel_drop_hires=args.wheel_drop_hires,
    )
    for dev in devices:
        try:
            dm = DelayedDebouncedMouse(dev, args.threshold,
                                       warn_threshold_ms=args.warn_threshold,
                                       hold_threshold_ms=args.hold_threshold,
                                       quiet=args.quiet,
                                       lag_threshold_ms=args.lag_threshold,
                                       button_remap=button_remap,
                                       diagnose_move=args.diagnose_move,
                                       diagnose_clicks=args.diagnose_clicks,
                                       debounce_enabled=args.debounce,
                                       diagnose_wheel=args.diagnose_wheel,
                                       **wheel_suppress_kwargs)
            mice.append(dm)
            log(f"Filtering: {dev.name} ({dev.path}) -> {dm.uinput.name}")
        except Exception as e:
            log(f"Error setting up {dev.name}: {e}")

    if not mice:
        log("No devices could be set up.")
        sys.exit(1)

    # Emit configuration summary at startup
    # In quiet mode, full config goes to log file only; stdout gets a short summary
    q = args.quiet
    log(f"mouse-filter started — {len(mice)} device(s)")
    log(f"  Debounce:          {'ON' if args.debounce else 'OFF (--debounce to enable)'}",
        also_print=not q)
    if args.debounce:
        log(f"  Hold threshold:    {args.hold_threshold}ms  "
            f"(holds < {args.hold_threshold}ms = click, >= {args.hold_threshold}ms = drag)",
            also_print=not q)
        log(f"  Debounce window:   {args.threshold}ms  "
            f"(release held this long before forwarding)", also_print=not q)
        log(f"  Warn threshold:    {args.warn_threshold}ms  "
            f"(NEAR-MISS logged for gaps {args.threshold}–{args.warn_threshold}ms)",
            also_print=not q)
    log(f"  Lag threshold:     {args.lag_threshold}ms  "
        f"(LAG_SPIKE logged when processing > {args.lag_threshold}ms behind kernel)",
        also_print=not q)
    log(f"  Stats interval:    {args.stats_interval}s", also_print=not q)
    log(f"  Quiet mode:        {'on' if q else 'off'}", also_print=not q)
    log(f"  Log file:          {LOG_FILE}", also_print=not q)
    log(f"", also_print=not q)
    log(f"  Behavior summary:", also_print=not q)
    if args.debounce:
        log(f"    Click releases (hold < {args.hold_threshold}ms):   forwarded immediately",
            also_print=not q)
        log(f"    Drag releases  (hold >= {args.hold_threshold}ms):  delayed {args.threshold}ms, bounce suppressed",
            also_print=not q)
        log(f"    Buttons filtered:        LEFT, RIGHT, MIDDLE, SIDE, EXTRA",
            also_print=not q)
    else:
        log(f"    All button releases:     forwarded immediately (debounce off)",
            also_print=not q)
    if button_remap:
        def _ecode_name(code):
            """Get a single human-readable name for an evdev code."""
            for mapping in (ecodes.BTN, ecodes.KEY):
                name = mapping.get(code)
                if name is not None:
                    return name if isinstance(name, str) else name[-1]
            return str(code)
        for src, dst in button_remap.items():
            log(f"    Remap:                   {_ecode_name(src)} ({src}) -> {_ecode_name(dst)} ({dst})",
                also_print=not q)
    if args.diagnose_move:
        log(f"  Move diagnostics:  ENABLED (reports at each stats interval)")
    if args.diagnose_clicks:
        log(f"  Click diagnostics: ENABLED (logging to {LOG_FILE})")
    if args.diagnose_wheel:
        log(f"  Wheel diagnostics: ENABLED (logging to {LOG_FILE})")
    log(f"  Wheel multiplier:  {args.wheel_multiplier}x  "
        f"(forwarded wheel event values scaled)",
        also_print=not q)
    log(f"  Wheel drop hi-res: {'ON' if args.wheel_drop_hires else 'off'}  "
        f"(REL_WHEEL_HI_RES axis dropped before uinput)",
        also_print=not q)
    log(f"  Wheel suppress:    {'ON' if args.wheel_suppress else 'OFF'}  "
        f"(toggle: systemctl kill -s SIGUSR2 mouse-filter.service)",
        also_print=not q)
    if args.wheel_suppress:
        log(f"    Type A (reversal):       ON (single-step opposite, "
            f"fires once per anchor)",
            also_print=not q)
        log(f"    Type B (same-direction): "
            f"{'ON (--wheel-type-b)' if args.wheel_type_b else 'off'}",
            also_print=not q)
        log(f"    cooldown_ms={args.wheel_cooldown_ms}  "
            f"rev_window_ms={args.wheel_rev_window_ms}  "
            f"cooldown_ratio={args.wheel_cooldown_ratio}",
            also_print=not q)
        log(f"    min_primary={args.wheel_min_primary}  "
            f"bounce_max_total={args.wheel_bounce_max_total}  "
            f"quiet_ms={args.wheel_quiet_ms}",
            also_print=not q)
    # Always log the initial toggle state — mouse-suppress status reads this.
    log(f"WHEEL_SUPPRESS_TOGGLE: {'on' if args.wheel_suppress else 'off'}")

    running = True

    def cleanup(sig=None, frame=None):
        nonlocal running
        running = False

    signal.signal(signal.SIGINT, cleanup)
    signal.signal(signal.SIGTERM, cleanup)

    def handle_user_tag(sig, frame):
        log_user_tag()

    signal.signal(signal.SIGUSR1, handle_user_tag)

    # SIGUSR2: toggle wheel-bounce suppression at runtime. The mice list is
    # passed by reference so hotplug additions are picked up on the next
    # signal. The polkit rule installed by install.sh permits the invoking
    # user to send signals to this service without auth.
    signal.signal(signal.SIGUSR2, make_wheel_suppress_toggle(mice))

    # Build fd -> mouse mapping for select()
    fd_map = {m.device.fd: m for m in mice}
    last_stats = time.monotonic()

    # Watch /dev/input/ for new devices via inotify (zero-overhead until event)
    monitor_fd = -1
    if not args.device:
        monitor_fd = init_inotify()
        if monitor_fd >= 0:
            log(f"  Device hotplug:    watching /dev/input/ via inotify")
        else:
            log(f"  Device hotplug:    inotify unavailable, no auto-reconnect")

    # Start X11 pointer probe for move diagnostics
    x11_probe = None
    if args.diagnose_move:
        # Use the first mouse's diag instance for the probe
        first_diag = mice[0]._move_diag
        x11_probe = X11PointerProbe(first_diag)
        if x11_probe.start():
            log(f"  X11 probe:         active (polling at {X11PointerProbe.POLL_HZ}Hz)")
        else:
            log(f"  X11 probe:         unavailable (no $DISPLAY or Xlib)")
            x11_probe = None

    while running:
        # Calculate select timeout: need to flush pending releases on time
        timeout = None
        for m in mice:
            dl = m.next_deadline()
            if dl is not None:
                timeout = dl if timeout is None else min(timeout, dl)
        if timeout is None:
            timeout = 1.0  # Wake up periodically for stats

        # Build FD list: mouse devices + inotify monitor
        watch_fds = list(fd_map.keys())
        if monitor_fd >= 0:
            watch_fds.append(monitor_fd)

        try:
            readable, _, _ = select.select(watch_fds, [], [], timeout)
        except (KeyboardInterrupt, ValueError):
            break

        loop_start = time.monotonic()

        # Process readable devices
        for fd in readable:
            if fd == monitor_fd:
                continue  # Handle inotify below
            mouse = fd_map[fd]
            try:
                if args.diagnose_move:
                    # Materialize to list for batch counting
                    events = list(mouse.device.read())
                    if mouse._move_diag:
                        mouse._move_diag.record_batch(len(events))
                    for event in events:
                        mouse.process_event(event)
                else:
                    for event in mouse.device.read():
                        mouse.process_event(event)
            except OSError:
                log(f"Device disconnected: {mouse.name}")
                mouse.close()
                del fd_map[fd]
                mice.remove(mouse)

        # Handle inotify: new device appeared in /dev/input/
        if monitor_fd in readable:
            new_paths = drain_inotify(monitor_fd)
            active_paths = {m.device.path for m in mice}
            for path in new_paths:
                dev = check_new_device(path, active_paths)
                if dev is None:
                    continue
                try:
                    dm = DelayedDebouncedMouse(
                        dev, args.threshold,
                        warn_threshold_ms=args.warn_threshold,
                        hold_threshold_ms=args.hold_threshold,
                        quiet=args.quiet,
                        lag_threshold_ms=args.lag_threshold,
                        button_remap=button_remap,
                        diagnose_move=args.diagnose_move,
                        diagnose_clicks=args.diagnose_clicks,
                        debounce_enabled=args.debounce,
                        diagnose_wheel=args.diagnose_wheel,
                        **wheel_suppress_kwargs)
                    mice.append(dm)
                    fd_map[dm.device.fd] = dm
                    active_paths.add(dev.path)
                    log(f"Reconnected: {dev.name} ({dev.path}) -> {dm.uinput.name}")
                except Exception as e:
                    log(f"Error setting up reconnected {dev.name}: {e}")

        # Flush expired pending releases
        for m in mice:
            m.flush_pending()

        # Record loop iteration time for diagnostics
        if args.diagnose_move:
            loop_elapsed_ms = (time.monotonic() - loop_start) * 1000
            for m in mice:
                if m._move_diag:
                    m._move_diag.record_loop_time(loop_elapsed_ms)

        # Periodic stats
        now = time.monotonic()
        if now - last_stats > args.stats_interval:
            for m in mice:
                # In quiet mode, only log stats when something notable happened
                should_log = not args.quiet or m.has_notable_events()

                if m._move_diag:
                    verdict = m._move_diag.verdict()
                    if verdict != "CLEAN":
                        should_log = True
                    if should_log:
                        log(f"STATS: {m.name}: clicks={m.total_clicks}, "
                            f"suppressed={m.suppressed}, events={m.total_events}, "
                            f"lag_spikes={m.lag_spikes}, max_lag={m.max_lag_ms:.1f}ms")
                        log(m._move_diag.report())
                    m._move_diag.reset()
                elif should_log:
                    log(f"STATS: {m.name}: clicks={m.total_clicks}, "
                        f"suppressed={m.suppressed}, events={m.total_events}, "
                        f"lag_spikes={m.lag_spikes}, max_lag={m.max_lag_ms:.1f}ms")
                m.record_stats()
                m.max_lag_ms = 0.0  # Reset per interval
            last_stats = now

    # Cleanup
    if x11_probe:
        x11_probe.stop()
    if monitor_fd >= 0:
        os.close(monitor_fd)
    for m in mice:
        log(f"FINAL: {m.name}: clicks={m.total_clicks}, suppressed={m.suppressed}")
        m.close()
    log("Debounce filter stopped.")


if __name__ == "__main__":
    main()
